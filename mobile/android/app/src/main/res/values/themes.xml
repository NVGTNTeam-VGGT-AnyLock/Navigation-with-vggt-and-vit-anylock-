<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.NaviSense" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand colours -->
        <item name="colorPrimary">@color/naviSense_primary</item>
        <item name="colorPrimaryVariant">@color/naviSense_primary_variant</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand colours -->
        <item name="colorSecondary">@color/naviSense_secondary</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/surface_dark</item>
        <item name="android:navigationBarColor">@color/surface_dark</item>

        <!-- Backgrounds -->
        <item name="android:windowBackground">@color/surface_dark</item>

        <!-- Material3 night/dark overrides -->
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorOnSurfaceVariant">@color/white</item>
    </style>

    <!-- BottomSheet dark theme -->
    <style name="Theme.NaviSense.BottomSheet" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorOnSurfaceVariant">@color/white</item>
    </style>

</resources>
